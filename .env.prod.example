# Production environment file
# Скопируйте этот файл в .env и заполните реальные значения

# Django Settings
SECRET_KEY=django-insecure-change-me-to-real-key
DEBUG=False
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com

# Database
DB_ENGINE=django.db.backends.postgresql
DB_NAME=starburger_prod
DB_USER=starburger_prod
DB_PASSWORD=change-me-to-secure-password
DB_HOST=db
DB_PORT=5432

# API Keys
YANDEX_GEOCODE_API_KEY=your-yandex-api-key
ROLLBAR_ACCESS_TOKEN=your-rollbar-token

# Security
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
